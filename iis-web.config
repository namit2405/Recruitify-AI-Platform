<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- Proxy API requests to Django backend -->
                <rule name="Django API" stopProcessing="true">
                    <match url="^api/(.*)$" />
                    <action type="Rewrite" url="http://localhost:8000/api/{R:1}" />
                </rule>
                
                <!-- Proxy admin requests to Django backend -->
                <rule name="Django Admin" stopProcessing="true">
                    <match url="^admin/(.*)$" />
                    <action type="Rewrite" url="http://localhost:8000/admin/{R:1}" />
                </rule>
                
                <!-- Proxy media files to Django backend -->
                <rule name="Django Media" stopProcessing="true">
                    <match url="^media/(.*)$" />
                    <action type="Rewrite" url="http://localhost:8000/media/{R:1}" />
                </rule>
                
                <!-- Proxy static files to Django backend -->
                <rule name="Django Static" stopProcessing="true">
                    <match url="^static/(.*)$" />
                    <action type="Rewrite" url="http://localhost:8000/static/{R:1}" />
                </rule>
                
                <!-- Serve static assets (images, fonts, etc.) directly -->
                <rule name="Static Assets" stopProcessing="true">
                    <match url="^(images|assets|fonts)/(.*)$" />
                    <action type="None" />
                </rule>
                
                <!-- Serve React frontend for all other requests -->
                <rule name="React Routes" stopProcessing="true">
                    <match url=".*" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="/index.html" />
                </rule>
            </rules>
        </rewrite>
        
        <!-- Security headers -->
        <httpProtocol>
            <customHeaders>
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="SAMEORIGIN" />
                <add name="X-XSS-Protection" value="1; mode=block" />
            </customHeaders>
        </httpProtocol>
        
        <!-- Static content settings -->
        <staticContent>
            <remove fileExtension=".json" />
            <mimeMap fileExtension=".json" mimeType="application/json" />
            <remove fileExtension=".woff" />
            <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
            <remove fileExtension=".woff2" />
            <mimeMap fileExtension=".woff2" mimeType="application/font-woff2" />
            <remove fileExtension=".avif" />
            <mimeMap fileExtension=".avif" mimeType="image/avif" />
        </staticContent>
    </system.webServer>
</configuration>
